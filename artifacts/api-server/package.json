    "@workspace/chain-core": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "ethers": "^6.17.0",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "esbuild": "0.27.3",
