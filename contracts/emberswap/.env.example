# Copy to .env and fill in values before deploying

# Deployer private key (hex, with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...

# Bridge relayer wallet address (the server address that will call bridgeIn / releaseEMBR)
RELAYER_ADDRESS=0x...

# RPC endpoints
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_MAINNET_RPC=https://mainnet.base.org
EMBR_RPC=http://localhost:3001

# Uniswap V2 Router02 addresses
# Base Sepolia: check https://docs.uniswap.org/contracts/v2/reference/smart-contracts/router-02
UNISWAP_V2_ROUTER_BASE_SEPOLIA=0x...
# Base Mainnet: 0x4752ba5dbc23f44d87826276bf6fd6b1c372ad24
UNISWAP_V2_ROUTER_BASE_MAINNET=0x4752ba5dbc23f44d87826276bf6fd6b1c372ad24

# Basescan API key for contract verification (optional)
BASESCAN_API_KEY=
