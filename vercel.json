{
  "buildCommand": "pnpm install && pnpm --filter @workspace/wallet build",
  "outputDirectory": "artifacts/wallet/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "version": 2
}
